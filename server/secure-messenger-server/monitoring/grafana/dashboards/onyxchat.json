      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[1m])) by (status)",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        },
        {
          "expr": "rate(http_rate_limit_rejections_total[1m])",
          "legendFormat": "Rate Limited",
          "refId": "B"
        }
      ],
      "title": "Error & Rate Limit Rate",
      "type": "timeseries"
    },
    {
