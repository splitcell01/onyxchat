# Copy this to .env.prod and fill in real values on the server

# Example for a managed Postgres:
# SM_DB_DSN=postgres://USER:PASS@HOST:5432/secure_messenger?sslmode=require
SM_DB_DSN=postgres://securechat:CHANGE_ME@db-hostname:5432/secure_messenger?sslmode=require

SM_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
SM_ADDR=:8080
SM_TLS_CERT_PATH=/path/to/fullchain.pem
SM_TLS_KEY_PATH=/path/to/privkey.pem
SM_LOG_LEVEL=info
SM_LOG_FORMAT=json
SM_HTTPS_REDIRECT=true
SM_HTTPS_PORT=443
SM_HTTP_PORT=80