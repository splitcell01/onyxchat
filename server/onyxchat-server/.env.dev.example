# server
SM_SERVER_ADDR=:8080
JWT_SECRET=change_me  # ⚠️ insecure placeholder — use a long random secret in any real environment

# db (compose service name "db")
SM_DB_DSN=postgres://securechat:change-me@db:5432/secure_messenger?sslmode=disable

# redis (compose service name "redis")
SM_REDIS_ADDR=redis:6379

# observability
LOG_LEVEL=info
METRICS_ENABLED=true
OTEL_TRACES_ENABLED=false
SERVICE_NAME=onyxchat-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317